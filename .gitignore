# --- Node.js (frontend build) ---
# node_modules: dependencias locales, no se commitean (npm install las recrea).
# *.min.js + tailwind.css: build artifacts generados por `npm run build`.
#           En desarrollo se usan los .js originales; en Docker se regeneran.
frontend/node_modules/
**/*.min.js
**/*.min.js.map
frontend/public/tailwind.css

# Alembic
backend/alembic/versions/__pycache__/

  # Docker volumes
  postgres_data/
  pgadmin_data/

  # Cloudflare credentials (never commit real API tokens)
  certbot/cloudflare.ini
