# === DATABASE ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=logistica
POSTGRES_USER=logistica
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://logistica:CHANGE_ME_STRONG_PASSWORD@localhost:5432/logistica

# === TEST DATABASE ===
TEST_DATABASE_URL=postgresql+asyncpg://logistica:CHANGE_ME_STRONG_PASSWORD@localhost:5432/logistica_test

# === JWT ===
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === ZENVIA WHATSAPP API ===
ZENVIA_API_KEY=YOUR_ZENVIA_API_KEY
ZENVIA_API_URL=https://api.zenvia.com/v2
ZENVIA_CHANNEL_ID=YOUR_WHATSAPP_CHANNEL_ID
ZENVIA_WEBHOOK_TOKEN=YOUR_WEBHOOK_TOKEN

# Zenvia template names (must match templates in Zenvia dashboard)
ZENVIA_TEMPLATE_INVITATION=event_invitation
ZENVIA_TEMPLATE_REMINDER_1D=reminder_1d
ZENVIA_TEMPLATE_REMINDER_5D=reminder_5d

# Keywords operators text to confirm/reject via WhatsApp
ZENVIA_CONFIRM_KEYWORDS=CONFIRMAR,SI,SÍ,CONFIRMO,CONFIRM
ZENVIA_REJECT_KEYWORDS=RECHAZAR,NO,RECHAZO,REJECT

# === APP ===
APP_NAME=AyC Eventos - Gestión de Personal Eventual
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=https://ayceventos.com.co,https://www.ayceventos.com.co

# === PHOTOS ===
PHOTOS_DIR=./data/photos
PHOTOS_THUMBNAIL_DIR=./data/photos/thumbnails
PHOTO_MAX_SIZE_MB=5

# === PGADMIN ===
PGADMIN_EMAIL=admin@logistica.com
PGADMIN_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050