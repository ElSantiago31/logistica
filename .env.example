# === DATABASE ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=logistica
POSTGRES_USER=logistica
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://logistica:CHANGE_ME_STRONG_PASSWORD@localhost:5432/logistica

# === TEST DATABASE ===
TEST_DATABASE_URL=postgresql+asyncpg://logistica:CHANGE_ME_STRONG_PASSWORD@localhost:5432/logistica_test

# === JWT ===
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === WHATSAPP META API ===
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID
WHATSAPP_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
WHATSAPP_WEBHOOK_VERIFY_TOKEN=YOUR_VERIFY_TOKEN
WHATSAPP_APP_SECRET=YOUR_APP_SECRET

# === APP ===
APP_NAME=Logistica - Gestión de Personal Eventual
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=https://yourdomain.com

# === PHOTOS ===
PHOTOS_DIR=./data/photos
PHOTOS_THUMBNAIL_DIR=./data/photos/thumbnails
PHOTO_MAX_SIZE_MB=5

# === PGADMIN ===
PGADMIN_EMAIL=admin@logistica.com
PGADMIN_PASSWORD=CHANGE_ME
PGADMIN_PORT=5050